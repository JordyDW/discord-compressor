{
  "name": "discord-compressor",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@react-native-camera-roll/camera-roll": "^7.10.2",
    "expo": "~57.0.1",
    "expo-constants": "~57.0.2",
    "expo-file-system": "~57.0.0",
    "expo-image-picker": "~57.0.1",
    "expo-keep-awake": "~57.0.0",
    "expo-linking": "~57.0.1",
    "expo-share-intent": "^7.0.0",
    "expo-status-bar": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-compressor": "^2.0.2",
    "react-native-nitro-modules": "^0.36.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-share": "^12.3.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "babel-jest": "^29.7.0",
    "babel-preset-expo": "~57.0.1",
    "jest": "~29.7.0",
    "typescript": "~6.0.3"
  },
  "overrides": {
    "expo-share-intent": {
      "expo-constants": "$expo-constants",
      "expo-linking": "$expo-linking"
    }
  },
  "scripts": {
    "start": "adb reverse tcp:8081 tcp:8081 && expo start --dev-client --localhost",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/*.test.ts"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json"
    ],
    "transform": {
      "^.+\\.(ts|tsx|js|jsx)$": "babel-jest"
    }
  },
  "private": true
}
